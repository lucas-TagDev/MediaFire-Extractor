{
  "manifest_version": 3,
  "name": "MediaFire Link Extractor",
  "version": "1.0.0",
  "description": "Escaneia a página, coleta todos os links do MediaFire e baixa individualmente ou todos de uma vez.",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "tabs"
  ],
  "host_permissions": [
    "*://*.mediafire.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "MediaFire Link Extractor",
    "default_popup": "popup.html"
  }
}
